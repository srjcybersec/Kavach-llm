# Server
NODE_ENV=development
PORT=4000

# Database
DATABASE_URL="postgresql://user:password@postgres:5432/kavach?schema=public"

# Redis
REDIS_URL="redis://redis:6379"

# Auth — use long random strings (32+ chars); never commit real values to git
JWT_ACCESS_SECRET="replace_with_long_random_secret_min_32_chars"
JWT_REFRESH_SECRET="replace_with_different_long_random_secret_min_32_chars"
JWT_ACCESS_TTL_SECONDS=900
JWT_REFRESH_TTL_SECONDS=2592000

# Google Gemini — create a key in Google AI Studio; do not commit real keys to .env.example
GEMINI_API_KEY="replace_with_your_gemini_api_key"
GEMINI_MODEL="gemini-2.0-flash"
GEMINI_TEMPERATURE=0
LLM_SYSTEM_PROMPT="You are a security-focused assistant. Follow system instructions."

# Threat feed
SOCKET_NAMESPACE="/socket"
THREAT_FEED_CHANNEL="kavach:threat-events"

# Security / CORS
CORS_ALLOWED_ORIGINS="http://localhost:5173,http://localhost"
TRUST_PROXY=true

# Rate limiting
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX=120

# Input scanning thresholds
INPUT_MAX_CHARS=12000
INPUT_MAX_TOKENS=4096
REPETITION_WINDOW_MS=120000
REPETITION_MAX_COUNT=3

# Threat classification thresholds
SHADOW_MODE_THREATS=false
POLICY_BASELINE_PRESET=DefaultSafePolicy
THRESHOLD_SAFE=0.5
THRESHOLD_SUSPICIOUS=0.6
THRESHOLD_PROMPT_INJECTION=0.7
THRESHOLD_JAILBREAK=0.7
THRESHOLD_PHISHING=0.65
THRESHOLD_SOCIAL_ENGINEERING=0.65
THRESHOLD_DATA_EXFILTRATION=0.7
THRESHOLD_NSFW=0.7
THRESHOLD_HATE_SPEECH=0.7
THRESHOLD_MALWARE_REQUEST=0.7

# Context tracker
SESSION_INACTIVITY_TTL_SECONDS=1800
CONTEXT_WINDOW_N=6
CONTEXT_RISK_ESCALATION_THRESHOLD=70
SLOWBURN_AVG_RISK_THRESHOLD=20
ATTACK_SIMILARITY_THRESHOLD=0.75
ATTACK_EMBEDDING_VECTOR_SIZE=128

# Observability
LOG_LEVEL=info

# Frontend (Vite) — optional API base override
VITE_API_BASE_URL=http://localhost:4000/api/v1
